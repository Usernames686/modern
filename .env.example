# CRMEB Modern Docker Compose defaults
#
# Copy this file to .env before production deployment if any value needs to change.
# Docker Compose uses ./legacy-deps/db/single_open_current.sql and ./legacy-deps/upload by default.

CRMEB_MYSQL_ROOT_PASSWORD=root
CRMEB_MYSQL_DATABASE=single_open
CRMEB_DB_USERNAME=crmeb
CRMEB_DB_PASSWORD=crmeb

CRMEB_MYSQL_PORT=3306
CRMEB_REDIS_PORT=6379
CRMEB_ADMIN_API_PORT=8080
CRMEB_FRONT_API_PORT=8081
CRMEB_ADMIN_WEB_PORT=9527
CRMEB_APP_WEB_PORT=9528

CRMEB_REDIS_DATABASE=6

CRMEB_DB_URL=jdbc:mysql://mysql:3306/single_open?useUnicode=true&characterEncoding=UTF8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
CRMEB_ADMIN_SITE_URL=http://127.0.0.1:9527
CRMEB_APP_SITE_URL=http://127.0.0.1:9528
